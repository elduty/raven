# Raven — example environment configuration
# Copy to .env and fill in your values.

# ── Gitea ──────────────────────────────────────────────────────────────────────
# HMAC-SHA256 shared secret configured in Gitea webhook settings.
GITEA_WEBHOOK_SECRET=changeme
# Base URL of your Gitea instance
GITEA_URL=https://gitea.example.com
# Personal access token with repo read + issue write + repo write permissions
GITEA_TOKEN=your_gitea_token_here

# ── Bitbucket Data Center (optional) ─────────────────────────────────────────
# BITBUCKET_DC_URL=https://bitbucket.example.com
# BITBUCKET_DC_TOKEN=your_token_here
# BITBUCKET_DC_WEBHOOK_SECRET=changeme
# BITBUCKET_DC_USERNAME=raven-bot

# ── AI backend selection ───────────────────────────────────────────────────────
# Raven auto-selects a backend from the credentials present. Set the
# credentials for the backend you want — at least one set is required;
# both can be present if you also set RAVEN_AI_BACKEND to pick the winner.
#   1) Claude Code CLI backend: CLAUDE_CODE_OAUTH_TOKEN
#   2) OpenAI-compatible backend (LiteLLM proxy, etc.):
#      RAVEN_AI_API_BASE + RAVEN_AI_API_KEY
# Auto-detect picks openai_compatible when both sets are present. To
# pin the choice explicitly:
#   RAVEN_AI_BACKEND=claude_cli   (or)   openai_compatible
# RAVEN_AI_BACKEND=

# ── Claude Code CLI backend ────────────────────────────────────────────────────
# Required only when using the claude_cli backend.
# Full JSON blob from: security find-generic-password -s "Claude Code-credentials" -w
# Or from: claude setup-token
# Can also be a bare access token (set CLAUDE_CODE_OAUTH_REFRESH_TOKEN separately)
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_json_or_token_here
# Only needed if CLAUDE_CODE_OAUTH_TOKEN is a bare token string (not JSON blob)
# CLAUDE_CODE_OAUTH_REFRESH_TOKEN=sk-ant-ort01-...

# ── OpenAI-compatible backend ──────────────────────────────────────────────────
# Alternative to CLAUDE_CODE_OAUTH_TOKEN. Point at any endpoint that
# speaks OpenAI chat/completions (LiteLLM, vLLM, OpenRouter, actual
# OpenAI, etc.). RAVEN_AI_MODEL must match what the endpoint routes
# (e.g. claude-opus-4-7, anthropic/claude-opus-4-7, or a proxy alias).
# RAVEN_AI_API_BASE=http://proxy.example:4000
# RAVEN_AI_API_KEY=your-key-here
# Optional output cap. Lift this if long reviews truncate mid-JSON
# (GPT-4o defaults to 16k output; gpt-5 / Claude support far more).
# Leave unset to use the model's default.
# RAVEN_AI_MAX_TOKENS=32768
# If your routed model doesn't support reasoning_effort and the proxy
# doesn't strip it, set RAVEN_AI_EFFORT=none (and RAVEN_AI_EFFORT_COMMENT=none)
# above to omit the kwarg.

# ── Notifications ─────────────────────────────────────────────────────────────
# JSON array of notification channels. Omit or set to [] to disable notifications.
# Supported types: "slack", "webhook"
# Add "repos": ["owner/repo"] to limit a channel to specific repos (omit for all).
# Add "min_severity": "medium" to only notify at or above that severity (omit for all).
# NOTIFY_CHANNELS=[{"type":"slack","url":"https://hooks.slack.com/services/...","min_severity":"medium"}]

# ── Review behaviour ───────────────────────────────────────────────────────────
# Approve PRs at or below this severity (low | medium | high)
REVIEW_APPROVE_MAX_SEVERITY=low
# Merge strategy when auto-merging (squash | merge | rebase)
MERGE_STRATEGY=squash
# Maximum diff lines before splitting review by file (most PRs stay under this)
MAX_DIFF_LINES=3000
# Seconds to wait for CI to finish before giving up (0 = skip CI check)
CI_WAIT_TIMEOUT=300
# Comma-separated list of repos to skip entirely (e.g. owner/repo1,owner/repo2)
SKIP_REPOS=
# Comma-separated list of additional bot/author names to skip
SKIP_AUTHORS=
# Use Gitea's native auto-merge (queue merge, let Gitea wait for CI).
# Only applies to Gitea provider — BB DC has no equivalent REST flag and
# relies on server-side repo merge checks instead. When false (default),
# Raven polls CI itself before merging, which works on every provider.
# RAVEN_GITEA_AUTO_MERGE=false
# ── Review engagement mode ─────────────────────────────────────────────────────
# Controls which PRs Raven engages with and whether the verdict is blocking.
#
#   all       — Auto-add Raven to every PR; submit formal review; auto-merge
#               when Raven is the sole reviewer (default).
#   gap       — Only auto-add when no other reviewer is listed; submit formal
#               review when engaged; auto-merge when sole.
#   advisory  — Never auto-add; post a non-blocking "Raven Recommendation"
#               comment with inline findings. Auto-merge disabled.
#
# RAVEN_REVIEW_MODE=all

# ── AI model & effort (apply to BOTH backends) ─────────────────────────────────
# Model for reviews. The string is whatever the active backend (and any
# upstream proxy) routes — e.g. claude-opus-4-7, anthropic/claude-opus-4-7,
# gpt-5, or a proxy-defined alias.
RAVEN_AI_MODEL=claude-opus-4-7
# Per-request timeout in seconds. Wall-clock ceiling (no SDK retries on
# the openai_compatible path).
RAVEN_AI_TIMEOUT=600
# Effort level for extended thinking / reasoning on PR reviews
# (none | low | medium | high | max). Use `none` to omit reasoning_effort
# entirely on non-reasoning models behind a proxy that doesn't strip it.
RAVEN_AI_EFFORT=max
# Effort level for conversational @mention / thread replies
# (none | low | medium | high | max). Defaults to medium because Q&A
# rarely benefits from max-thinking budget.
RAVEN_AI_EFFORT_COMMENT=medium

# ── Comment replies ────────────────────────────────────────────────────────────
# How many recent PR comments to pass to the AI backend as conversation
# context. Longer windows cost tokens; shorter windows lose early context.
RAVEN_COMMENT_HISTORY=20

# ── Repo-supplied review context ───────────────────────────────────────────────
# Directory whose *.md files are injected as "Repository Rules" in every
# review prompt. Flat listing (subdirectories ignored). Also hosts optional
# prompt overrides at <RAVEN_RULES_DIR>/raven/prompts/{review,respond}.md.
# Empty string disables both rule injection and prompt overrides.
# RAVEN_RULES_DIR=.claude/rules
# Per-item character cap for PR title/description/comments and each
# rule file. Truncation adds a visible marker so the model knows content
# was cut. 0 disables truncation (keep full text).
# RAVEN_REVIEW_PR_CONTEXT_ITEM_CHARS=4000
# Global budget for the PR Context block (title + description + comments).
# Comments added newest-first until the budget is hit.
# RAVEN_REVIEW_PR_CONTEXT_TOTAL_CHARS=16000
# Global budget for the Repository Rules block (all rule files
# concatenated). Files added in sorted order until the budget is hit.
# RAVEN_REVIEW_RULES_TOTAL_CHARS=16000
# Max non-bot comments kept in the review prompt's PR Context section.
# 0 disables the comments subsection entirely.
# RAVEN_REVIEW_COMMENT_CONTEXT=20

# ── Thread pools ───────────────────────────────────────────────────────────────
# Main review pool — handles webhook dispatch, diff fetch, Claude CLI,
# review submission. Most reviews finish in under a minute.
# RAVEN_MAX_WORKERS=16
# Dedicated pool for the post-review CI-wait-and-merge phase. These
# tasks spend nearly all their time sleeping between status polls
# (up to CI_WAIT_TIMEOUT) so running them on the main pool would
# starve incoming webhooks during bursts. Sized generously to
# accommodate many concurrent waits.
# RAVEN_CI_WAIT_WORKERS=32
# Max concurrent in-flight AI calls. Caps subprocesses for the
# claude_cli backend; caps simultaneous HTTP requests for the
# openai_compatible backend.
# RAVEN_AI_MAX_CONCURRENT=4

# ── Label ──────────────────────────────────────────────────────────────────────
# Label name applied to reviewed PRs in Gitea
RAVEN_LABEL_NAME=raven-reviewed

# ── Findings cache ─────────────────────────────────────────────────────────────
# Max PR entries kept in the persistent findings cache (LRU eviction).
# Older entries are dropped beyond this limit — tune up if you have many
# long-lived PRs that re-review frequently.
# RAVEN_MAX_CACHED_PRS=200

# ── Observability ──────────────────────────────────────────────────────────────
# Bearer token guarding the /metrics endpoint. Required: when unset, the
# endpoint returns 404 (does not advertise itself). When set, scrapers must
# send `Authorization: Bearer <token>`. Match in your Prometheus config via:
#   authorization: { credentials_file: /etc/prom/raven_metrics_token }
# /healthz remains open for load balancers and is unaffected.
# RAVEN_METRICS_TOKEN=

# ── Comment reply context budgets ──────────────────────────────────────────────
# Cap on the "## Active Thread" prompt block when replying to a PR comment.
# Preserves the thread root (Raven's original finding being discussed) plus
# the newest replies; drops from the middle and inserts a "[N earlier replies
# truncated]" marker. Naive oldest-first truncation would silently drop the
# root, leaving the AI replying without knowing what was originally flagged.
# Increase if PR threads routinely run long.
# RAVEN_RESPOND_THREAD_TOTAL_CHARS=8000
# Cap on the "## Your Prior Verdict" body when Raven might revise its verdict.
# Middle-truncates (keeps first + last paragraphs). Most formal review bodies
# fit comfortably under the default.
# RAVEN_RESPOND_VERDICT_BODY_CHARS=4000

# ── Comment retraction (finding-level resolve) ────────────────────────────────
# When the conversation invalidates a specific inline finding, Raven retracts
# it via the provider's native resolve action. Provider compatibility:
#   * Bitbucket Data Center: any version (sets threadResolved=true on PUT comments).
#   * Gitea: requires version >=1.24 (uses POST /pulls/comments/{id}/resolve).
#     On older Gitea, retract_finding logs a warning and no-ops — verdict
#     revision still works, but the comment stays open in the UI.
