# Raven — example environment configuration
# Copy to .env and fill in your values.

# ── Gitea ──────────────────────────────────────────────────────────────────────
# HMAC-SHA256 shared secret configured in Gitea webhook settings (previously RAVEN_WEBHOOK_SECRET — old name still works)
GITEA_WEBHOOK_SECRET=changeme
# Base URL of your Gitea instance
GITEA_URL=https://gitea.example.com
# Personal access token with repo read + issue write + repo write permissions
GITEA_TOKEN=your_gitea_token_here

# ── Bitbucket Data Center (optional) ─────────────────────────────────────────
# BITBUCKET_DC_URL=https://bitbucket.example.com
# BITBUCKET_DC_TOKEN=your_token_here
# BITBUCKET_DC_WEBHOOK_SECRET=changeme
# BITBUCKET_DC_USERNAME=raven-bot

# ── Claude Code OAuth ──────────────────────────────────────────────────────────
# Full JSON blob from: security find-generic-password -s "Claude Code-credentials" -w
# Or from: claude setup-token
# Can also be a bare access token (set CLAUDE_CODE_OAUTH_REFRESH_TOKEN separately)
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_json_or_token_here
# Only needed if CLAUDE_CODE_OAUTH_TOKEN is a bare token string (not JSON blob)
# CLAUDE_CODE_OAUTH_REFRESH_TOKEN=sk-ant-ort01-...

# ── Notifications ─────────────────────────────────────────────────────────────
# JSON array of notification channels. Omit or set to [] to disable notifications.
# Supported types: "slack", "webhook"
# Add "repos": ["owner/repo"] to limit a channel to specific repos (omit for all).
# Add "min_severity": "medium" to only notify at or above that severity (omit for all).
# NOTIFY_CHANNELS=[{"type":"slack","url":"https://hooks.slack.com/services/...","min_severity":"medium"}]

# ── Review behaviour ───────────────────────────────────────────────────────────
# Approve PRs at or below this severity (low | medium | high)
REVIEW_APPROVE_MAX_SEVERITY=low
# Merge strategy when auto-merging (squash | merge | rebase)
MERGE_STRATEGY=squash
# Maximum diff lines before splitting review by file (most PRs stay under this)
MAX_DIFF_LINES=3000
# Seconds to wait for CI to finish before giving up (0 = skip CI check)
CI_WAIT_TIMEOUT=300
# Comma-separated list of repos to skip entirely (e.g. owner/repo1,owner/repo2)
SKIP_REPOS=
# Comma-separated list of additional bot/author names to skip
SKIP_AUTHORS=
# Use Gitea's native auto-merge (queue merge, let Gitea wait for CI).
# Only applies to Gitea provider — BB DC has no equivalent REST flag and
# relies on server-side repo merge checks instead. When false (default),
# Raven polls CI itself before merging, which works on every provider.
# RAVEN_GITEA_AUTO_MERGE=false
# Auto-merge when a human approves a PR that Raven already approved.
# Requires all reviewers to have approved (no outstanding REQUEST_CHANGES).
# RAVEN_AUTO_MERGE_ON_APPROVAL=false

# ── Claude CLI ─────────────────────────────────────────────────────────────────
# Model for reviews (most capable with extended thinking)
CLAUDE_MODEL=claude-opus-4-6
# Timeout in seconds for each Claude CLI invocation (default 600)
CLAUDE_TIMEOUT=600
# Effort level for extended thinking on PR reviews (low | medium | high | max)
CLAUDE_EFFORT=max
# Effort level for conversational @mention / thread replies. Defaults to
# medium because Q&A rarely benefits from max-thinking budget.
CLAUDE_EFFORT_COMMENT=medium

# ── Comment replies ────────────────────────────────────────────────────────────
# How many recent PR comments to pass to Claude as conversation context.
# Longer windows cost tokens; shorter windows lose early context.
RAVEN_COMMENT_HISTORY=20

# ── Repo-supplied review context ───────────────────────────────────────────────
# Directory whose *.md files are injected as "Repository Rules" in every
# review prompt. Flat listing (subdirectories ignored). Empty string
# disables the feature entirely.
# RAVEN_RULES_DIR=.claude/rules
# Per-item character cap for PR title/description/comments and each
# rule file. Truncation adds a visible marker so the model knows content
# was cut. 0 disables truncation (keep full text).
# RAVEN_REVIEW_PR_CONTEXT_ITEM_CHARS=4000
# Global budget for the PR Context block (title + description + comments).
# Comments added newest-first until the budget is hit.
# RAVEN_REVIEW_PR_CONTEXT_TOTAL_CHARS=16000
# Global budget for the Repository Rules block (all rule files
# concatenated). Files added in sorted order until the budget is hit.
# RAVEN_REVIEW_RULES_TOTAL_CHARS=16000
# Max non-bot comments kept in the review prompt's PR Context section.
# 0 disables the comments subsection entirely.
# RAVEN_REVIEW_COMMENT_CONTEXT=20

# ── Thread pools ───────────────────────────────────────────────────────────────
# Main review pool — handles webhook dispatch, diff fetch, Claude CLI,
# review submission. Most reviews finish in under a minute.
# RAVEN_MAX_WORKERS=16
# Dedicated pool for the post-review CI-wait-and-merge phase. These
# tasks spend nearly all their time sleeping between status polls
# (up to CI_WAIT_TIMEOUT) so running them on the main pool would
# starve incoming webhooks during bursts. Sized generously to
# accommodate many concurrent waits.
# RAVEN_CI_WAIT_WORKERS=32
# Max concurrent Claude CLI subprocesses (limits memory usage)
# RAVEN_MAX_CONCURRENT_CLAUDE=4

# ── Label ──────────────────────────────────────────────────────────────────────
# Label name applied to reviewed PRs in Gitea
RAVEN_LABEL_NAME=raven-reviewed

# ── Findings cache ─────────────────────────────────────────────────────────────
# Max PR entries kept in the persistent findings cache (LRU eviction).
# Older entries are dropped beyond this limit — tune up if you have many
# long-lived PRs that re-review frequently.
# RAVEN_MAX_CACHED_PRS=200
